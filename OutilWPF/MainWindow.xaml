<Window x:Class="OutilWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:local="clr-namespace:OutilWPF"
        mc:Ignorable="d"
        Title="CLE Patients" Height="1261" Width="1347" MinHeight="860" MinWidth="980" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        SizeChanged="MainWindow_SizeChanged">
    <ScrollViewer IsEnabled="{Binding EnableApplication, UpdateSourceTrigger=PropertyChanged}" VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style x:Key="HyperLinkButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock TextDecorations="Underline" FontWeight="Normal">
                            <ContentPresenter />
                            </TextBlock>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <!--<Setter Property="IsEnabled" Value="True"/>
                <Setter Property="Foreground" Value="#195AE0" />-->
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="true">
                        <Setter Property="Foreground" Value="Red" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Trigger>
                    <!--<DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>-->
                </Style.Triggers>
            </Style>
        </ScrollViewer.Resources>
        <StackPanel Margin="20">
            <Border Padding="22" CornerRadius="24" Background="#CCFFFDF8" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="CLE Patients" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                        <TextBlock Margin="0,6,0,0" Text="{Binding SelectedPatient.NomPrenom, TargetNullValue=Accueil cabinet}" FontSize="30" FontWeight="Bold" />
                        <TextBlock Margin="0,4,0,0" Text="Recherche, suivi clinique, RDV Outlook et impression de fiche dans un seul cockpit." />
                    </StackPanel>
                    <Border Grid.Column="1" Padding="14,10" CornerRadius="18" Background="{StaticResource Brush.SurfaceStrong}">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" Text="Session" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding SelectedPatient.Ville, TargetNullValue=Centre Etoile Laser}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Name="spLogin" Visibility="{Binding LoginVisibility, UpdateSourceTrigger=PropertyChanged}" Margin="0,24,0,0" Padding="34" MaxWidth="520" HorizontalAlignment="Center" CornerRadius="28" Background="#F7FFFDF8" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Connexion" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                    <TextBlock Text="Accéder au cockpit patient" FontSize="32" FontWeight="Bold" Margin="0,8,0,0" TextAlignment="Center"/>
                    <TextBlock Margin="0,10,0,0" Text="Choisissez un profil puis ouvrez la base commune pour démarrer la session." TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ErrorMessage" Text="" FontSize="16" Margin="0,16,0,0" Foreground="Red" TextAlignment="Center"/>
                    <TextBlock Margin="0,18,0,6" Text="Profil" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                    <ComboBox x:Name="cbLogin" ItemsSource="{Binding LesLogins}" DisplayMemberPath="Item1" SelectedValuePath="Item2" MinWidth="260" MaxWidth="320" HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,18,0,6" Text="Mot de passe" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                    <PasswordBox  x:Name="password" MinWidth="260" MaxWidth="320" HorizontalAlignment="Center" />
                    <WrapPanel HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Name="Valider" Content="Se connecter" Width="140" HorizontalAlignment="Center" Margin="0" Click="Valider_Click" Style="{StaticResource ActionButtonStyle}" />
                        <Button Name="Importer" Content="Importer" Width="110" HorizontalAlignment="Center" Margin="10,0,0,0" Click="Importer_Click" Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}" />
                        <Button Name="Migrate" Content="Migrer" Width="110" HorizontalAlignment="Center" Margin="10,0,0,0" Click="Migrate_Click"  Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid Name="spWork" Visibility="{Binding SpWorkVisibility, UpdateSourceTrigger=PropertyChanged}" Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkRowTop" Height="Auto" />
                    <RowDefinition x:Name="WorkRowBottom" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="WorkColumnLeft" Width="330" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition x:Name="WorkColumnRight" Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="PatientsCard" Grid.Row="0" Grid.Column="0" Padding="18" CornerRadius="22" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                <StackPanel MinWidth="280">
                    <TextBlock Text="Patients" FontSize="22" FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,10" Text="Recherche rapide et sélection de la fiche active." />
                    <Button Name="CréerNewFichePatient" HorizontalAlignment="Center" Margin="0,10,0,0" Content="Créer une nouvelle fiche patient" Click="CréerNewFichePatient_Click" Visibility="{Binding InfoPatientEditVisibility, UpdateSourceTrigger=PropertyChanged}" Background="LightSkyBlue"/>
                    <Label Content="Aucun enregistrement n'a été trouvé" HorizontalAlignment="Center" Foreground="Red" FontWeight="Bold" Visibility="{Binding SearchErrorVisibility, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGrid Name="ViewPatients" ItemsSource="{Binding PatientsSelectCollection, UpdateSourceTrigger=PropertyChanged}" Margin="10,10"  CanUserAddRows="False" Height="560" CanUserDeleteRows="False"  
                          SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto" AutoGenerateColumns="False" SelectedItem="{Binding SelectedPatientSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Panier" Binding="{Binding IsSelected}" />
                            <DataGridTextColumn IsReadOnly="True">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="{Binding Patient.CouleurLapin, UpdateSourceTrigger=PropertyChanged}" />
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="NOM" FontWeight="Bold" Binding="{Binding Patient.Nom, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" >
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Content, RelativeSource= {RelativeSource Mode=TemplatedParent}}"/>
                                            <TextBox x:Name="txtNom" Width="100" Text="{Binding DataContext.SearchSearchPatientNom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     GotKeyboardFocus="TextBox_GotKeyboardFocus">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding DataContext.FiltrerPatients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Prénom" Binding="{Binding Patient.Prénom, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Content, RelativeSource= {RelativeSource Mode=TemplatedParent}}"/>
                                            <TextBox x:Name="txtPrénom" Width="100" Text="{Binding DataContext.SearchSearchPatientPrénom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     GotKeyboardFocus="TextBox_GotKeyboardFocus">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding DataContext.FiltrerPatients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridCheckBoxColumn Header="PR" Binding="{Binding Patient.TarifRéduit, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
                </Border>
                <Border x:Name="DetailsCard" Grid.Row="0" Grid.Column="2" Padding="18" CornerRadius="22" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Parcours patient" FontSize="22" FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,14" Text="Fiche, actions rapides, séances et traitements dans une même vue clinique." />
                    <WrapPanel>
                        <Button Name="VisualiserFichePatient" HorizontalAlignment="Left" Content="Imprimer la fiche patient" Command="{Binding SelectedPatientCommand}" CommandParameter="VisualiserFichePatient" Style="{StaticResource ActionButtonStyle}"/>
                        <Button Name="OpenOutlook"  HorizontalAlignment="Left" Content="Saisir un nouveau RDV dans Outlook" Command="{Binding SelectedPatientCommand}" CommandParameter="OpenOutlook" Style="{StaticResource SubtleButtonStyle}" Margin="8,0"/>
                        <Button Name="CopyName"  HorizontalAlignment="Left" Content="Copier NOM Prénom" Command="{Binding SelectedPatientCommand}" CommandParameter="CopyName" Style="{StaticResource SubtleButtonStyle}" Margin="8,0"/>
                    </WrapPanel>
                    <StackPanel Margin="10">
                        <primitives:UniformGrid x:Name="PatientSectionsGrid" Columns="2">
                            <Border Margin="0,0,12,12" Padding="16" CornerRadius="18" Background="{StaticResource Brush.SurfaceStrong}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Identité" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Margin="0,10,0,6" Text="Nom" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientNom" Text="{Binding SelectedPatient.Nom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientNom" Text="{Binding SelectedPatient.Nom}" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Prénom" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientPrénom" Text="{Binding SelectedPatient.Prénom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientPrénom" Text="{Binding SelectedPatient.Prénom}" Visibility="{Binding InfoPatientViewVisibility}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="12,0,0,12" Padding="16" CornerRadius="18" Background="{StaticResource Brush.SurfaceStrong}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Coordonnées" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Margin="0,10,0,6" Text="Téléphone portable" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientTelephonePortable" Text="{Binding SelectedPatient.TelephonePortable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientTelephonePortable" Text="{Binding SelectedPatient.TelephonePortable}" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Ville" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientVille" Text="{Binding SelectedPatient.Ville, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientVille" Text="{Binding SelectedPatient.Ville}" Visibility="{Binding InfoPatientViewVisibility}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,12,0" Padding="16" CornerRadius="18" Background="{StaticResource Brush.SurfaceStrong}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Adresse" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Margin="0,10,0,6" Text="Adresse" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientAdresse1" Text="{Binding SelectedPatient.Adresse1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientAdresse1" Text="{Binding SelectedPatient.Adresse1}" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Complément" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientAdresse2" Text="{Binding SelectedPatient.Adresse2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientAdresse2" Text="{Binding SelectedPatient.Adresse2}" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Code postal" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientCodePostal" Text="{Binding SelectedPatient.CodePostal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientCodePostal" Text="{Binding SelectedPatient.CodePostal}" Visibility="{Binding InfoPatientViewVisibility}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="12,12,0,0" Padding="16" CornerRadius="18" Background="{StaticResource Brush.SurfaceStrong}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Suivi administratif" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Margin="0,10,0,6" Text="Commentaires" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <TextBox x:Name="EditPatientCommentaires" Text="{Binding SelectedPatient.Commentaires, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="TextBox_GotKeyboardFocus" Visibility="{Binding InfoPatientEditVisibility}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveInfosClients, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock x:Name="ViewPatientCommentaires" Text="{Binding SelectedPatient.Commentaires}" TextWrapping="Wrap" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Prix réduit" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <CheckBox x:Name="EditPatientPrixRéduit" IsChecked="{Binding SelectedPatient.TarifRéduit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="EditPatientPrixRéduit_Checked" Visibility="{Binding InfoPatientEditVisibility}"/>
                                    <TextBlock x:Name="ViewPatientPrixRéduit" Text="{Binding SelectedPatient.TarifRéduit}" Visibility="{Binding InfoPatientViewVisibility}" />

                                    <TextBlock Margin="0,14,0,6" Text="Lapin" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                    <ComboBox x:Name="EditPatientLapin" ItemsSource="{Binding ListLapins, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="LapinName" SelectedItem="{Binding SelectedPatient.Lapin, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding InfoPatientEditVisibility}" SelectionChanged="EditPatientLapin_SelectionChanged"/>
                                    <TextBlock x:Name="ViewPatientLapin" Text="{Binding SelectedPatient.Lapin.LapinName}" Visibility="{Binding InfoPatientViewVisibility}" />
                                </StackPanel>
                            </Border>
                        </primitives:UniformGrid>
                    </StackPanel>
                    <Separator Height="2"/>
                    <Grid Name="ClinicalLayoutGrid" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="ClinicalRowTop" Height="Auto" />
                            <RowDefinition x:Name="ClinicalRowBottom" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ClinicalColumnLeft" Width="320" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition x:Name="ClinicalColumnRight" Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="SessionsPanel" Grid.Row="0" Grid.Column="0">
                            <Label Content="Listes des séances" FontWeight="Bold"/>
                            <DataGrid Name="ViewSéances" ItemsSource="{Binding Séances, UpdateSourceTrigger=PropertyChanged}" CanUserDeleteRows="False"
                                  CanUserAddRows="false" AutoGenerateColumns="False" Height="420"  VerticalAlignment="Top" SelectionMode="Single" Width="Auto" RowEditEnding="ViewSéances_RowEditEnding"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateSéance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:dd/MM/yyyy}}"/>
                                    <DataGridTextColumn Header="Salle" Binding="{Binding Praticien.UserName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Changer salle" Command="{Binding  RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.ChangerSalleSéanceCommand}" CommandParameter="{Binding}" Style="{StaticResource HyperLinkButtonStyle}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Supprimer" Command="{Binding  RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.DeleteSéanceCommand}" CommandParameter="{Binding}" Style="{StaticResource HyperLinkButtonStyle}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        <StackPanel x:Name="TreatmentsPanel" Grid.Row="0" Grid.Column="2" Margin="0" VerticalAlignment="Top">
                            <StackPanel  Orientation="Vertical" IsEnabled="{Binding AddTraitementPanelEnabled , UpdateSourceTrigger=PropertyChanged}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="Date séance" Background="LightGreen"/>
                                    <DatePicker x:Name="EditSéanceDate" Grid.Row="1" Grid.Column="0" SelectedDate="{Binding EditSéanceDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Content="Salle" Background="LightGreen"/>
                                    <ComboBox x:Name="EditSéanceSalle" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" ItemsSource="{Binding LesPraticiens}" DisplayMemberPath="UserName" SelectedValuePath="UserName" SelectedItem="{Binding EditSéanceSalle, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}" Loaded="EditSéanceSalle_Loaded"/>
                                    <Label Grid.Row="0" Grid.Column="2" Content="Zone Traitée(*)" Background="LightGreen"/>
                                    <TextBox x:Name="EditSéanceZoneTraitée" Grid.Row="1" Grid.Column="2" Margin="8,0,0,0" Text="{Binding EditSéanceZoneTraitée, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Row="0" Grid.Column="3"  Content="Fluence(*)" Background="LightGreen"/>
                                    <TextBox x:Name="EditSéanceMS_Fluence" Grid.Row="1" Grid.Column="3"  Margin="8,0,0,0" Text="{Binding EditSéanceMS_Fluence, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}" />
                                    <Label Grid.Row="0" Grid.Column="4" Content="Pulses(*)" Background="LightGreen"/>
                                    <TextBox x:Name="EditSéanceNb_Pulses" Grid.Row="1" Grid.Column="4" Margin="8,0,0,0" Text="{Binding EditSéanceNb_Pulses, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}" />
                                    <Label Grid.Row="0" Grid.Column="5" Content="Commentaires" Background="LightGreen"/>
                                    <TextBox x:Name="EditSéanceCommentaires" Grid.Row="1" Grid.Column="5"  Margin="8,0,0,0" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding EditSéanceCommentaires, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}" />
                                    <Label Grid.Row="0" Grid.Column="6" Content="Prix" Background="LightGreen"/>
                                    <TextBox x:Name="EditSéancePrix" Grid.Row="1" Grid.Column="6" Margin="8,0,0,0" Text="{Binding EditSéancePrix, Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}" />
                                    <Label Grid.Row="0" Grid.Column="7" Content="Infos+" Background="LightGreen"/>
                                    <ComboBox x:Name="EditPatientInfosp" Grid.Row="1" Grid.Column="7" Margin="8,0,0,0" ItemsSource="{Binding ListInfosp, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="InfosName" SelectedItem="{Binding EditInfosp, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding InfoPatientEditVisibility, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Button Name="AddNewTraitement" Content="Ajouter cette ligne de traitement" Command="{Binding ExecuteCreerNouveauxTraitementCommand}" Width="Auto" Margin="0,8" HorizontalAlignment="Left" Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                            <DataGrid Name="ViewListeTraitement" ItemsSource="{Binding Traitements, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,8" CanUserAddRows="False" AutoGenerateColumns="False" Height="520"  CanUserDeleteRows="False" RowEditEnding="ViewListeTraitement_RowEditEnding"
                                          SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type TextBlock}" x:Key="WrapText">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>

                                </DataGrid.Resources>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{ Binding ZonesTraitées}" Value="lapin">
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{ Binding ZonesTraitées}" Value="Annulé le jour même">
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Width="110" IsReadOnly="True" Binding="{Binding Séance.DateSéance, Mode=TwoWay, StringFormat={}{0:dd/MM/yyyy}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Zones traitées" Width="2*" ElementStyle="{StaticResource WrapText}" Binding="{Binding ZonesTraitées, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Fluence" Width="*" Binding="{Binding Fluence, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Pulses" Width="*" Binding="{Binding Pulses, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Prix" Width="*" Binding="{Binding Prix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Commentaires" Width="2*" ElementStyle="{StaticResource WrapText}"  Binding="{Binding Commentaires, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTemplateColumn Header="Actions" IsReadOnly="True" >
                                        <DataGridTemplateColumn.CellTemplate >
                                            <DataTemplate >
                                                <TextBlock >
